// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id           Int       @id @unique @default(autoincrement())
  org_id       String
  title        String
  description  String?
  status       Status    @default(Unconfirmed)
  client_email String
  due_date     DateTime?
  start_date   DateTime  @default(now())
  end_date     DateTime?
  budget       Int
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  tasks        Task[]
}

model Task {
  id                   Int       @id @unique @default(autoincrement())
  project_id           Int       @unique
  title                String
  description          String?
  status               Status    @default(Unconfirmed)
  assigned_staff_email String
  priority             Priority  @default(NotSet)
  due_date             DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  project              Project   @relation(fields: [id], references: [id])
}

enum Status {
  Unconfirmed
  Todo
  InProgress
  Done
}

enum Priority {
  High
  Medium
  Low
  NotSet
}
